{
  "manifest_version": 3,
  "name": "PasteNinja",
  "version": "1.0.0",
  "description": "Slips past paste blockers, defending your god-given right to copy-and-paste.",
  "permissions": [],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
